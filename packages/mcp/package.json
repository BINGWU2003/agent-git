{
  "name": "@agentgit/mcp",
  "type": "module",
  "version": "0.0.0",
  "description": "MCP adapter for AgentGit Git checkpoint workflows.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "agentgit-mcp": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "@agentgit/core": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:mcp",
    "zod": "catalog:mcp"
  },
  "devDependencies": {
    "@agentgit/tsdown-config": "workspace:*"
  }
}
