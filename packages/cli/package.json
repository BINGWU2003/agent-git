{
  "name": "@agent-git/cli",
  "type": "module",
  "version": "1.0.0",
  "description": "Command-line adapter for Agent-Git Git checkpoint workflows.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "agent-git": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "tsx src/index.ts"
  },
  "devDependencies": {
    "@agent-git/core": "workspace:*",
    "@agent-git/typescript-config": "workspace:*"
  }
}
