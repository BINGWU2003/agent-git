{
  "name": "agent-git",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "description": "Git workflow toolkit for AI coding agents.",
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/agent-git/agent-git#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-git/agent-git.git"
  },
  "bugs": "https://github.com/agent-git/agent-git/issues",
  "keywords": [],
  "sideEffects": false,
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "dev": "turbo run dev",
    "lint": "eslint",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm build && changeset publish",
    "start": "pnpm --filter @agent-git/mcp start",
    "typecheck": "tsc",
    "version-packages": "changeset version",
    "prepare": "git config core.hooksPath .githooks && simple-git-hooks && skills-npm"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@changesets/cli": "catalog:cli",
    "@types/node": "catalog:types",
    "eslint": "catalog:cli",
    "nano-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "skills-npm": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli",
    "turbo": "catalog:cli",
    "typescript": "catalog:cli",
    "unrun": "catalog:cli"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && pnpm run build && npx nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
