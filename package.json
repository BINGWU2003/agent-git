{
  "name": "agentgit",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "description": "Git workflow toolkit for AI coding agents.",
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/agentgit/agentgit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentgit/agentgit.git"
  },
  "bugs": "https://github.com/agentgit/agentgit/issues",
  "keywords": [],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "pnpm --filter @agentgit/mcp start",
    "test": "pnpm run build && vitest run",
    "typecheck": "tsc",
    "prepare": "git config core.hooksPath .githooks && simple-git-hooks && skills-npm"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:cli",
    "@antfu/ni": "catalog:cli",
    "@antfu/utils": "catalog:inlined",
    "@modelcontextprotocol/sdk": "catalog:mcp",
    "@types/node": "catalog:types",
    "bumpp": "catalog:cli",
    "eslint": "catalog:cli",
    "nano-staged": "catalog:cli",
    "publint": "catalog:cli",
    "simple-git-hooks": "catalog:cli",
    "skills-npm": "catalog:cli",
    "tsdown": "catalog:cli",
    "tsdown-stale-guard": "catalog:testing",
    "tsnapi": "catalog:testing",
    "tsx": "catalog:cli",
    "typescript": "catalog:cli",
    "vite": "catalog:cli",
    "vitest": "catalog:testing",
    "zod": "catalog:mcp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && pnpm run build && npx nano-staged"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}
